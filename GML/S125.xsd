    <xs:simpleType name="categoryOfRadarTransponderBeaconLabel">
        <xs:annotation>
            <xs:documentation>Classification of radar transponder beacon based on functionality.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Ramark, Radar Beacon Transmitting Continuously">
                <xs:annotation>
                    <xs:documentation>A radar marker beacon which continuously transmits a signal appearing as a radial line on a radar screen, the line indicating the direction of the beacon. Ramarks are intended primarily for marine use. The name 'ramark' is derived from the words radar marker.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Racon, Radar Transponder Beacon">
                <xs:annotation>
                    <xs:documentation>A radar beacon which returns a coded signal which provides identification of the beacon, as well as range and bearing. The range and bearing are indicated by the location of the first character received on the radar screen. The name 'racon' is derived from the words radar beacon.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Leading Racon/Radar Transponder Beacon">
                <xs:annotation>
                    <xs:documentation>A radar beacon that may be used (in conjunction with at least one other radar beacon) to indicate a leading line.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
