                    <xs:documentation>A mark indicating that diving may take place in the vicinity.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Refuge Beacon">
                <xs:annotation>
                    <xs:documentation>A mark providing or indicating a place of safety.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Foul Ground Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating a foul ground.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Yachting Mark">
                <xs:annotation>
                    <xs:documentation>A mark installed for use by yachtsmen.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Heliport Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating an area where helicopters may land.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="GNSS Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating a location at which a GNSS position has been accurately determined.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Seaplane Landing Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating an area where seaplanes land.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Entry Prohibited Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating that entry is prohibited.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Work in Progress Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating that work (generally construction) is in progress.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mark With Unknown Purpose">
                <xs:annotation>
                    <xs:documentation>A mark whose detailed characteristics are unknown.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Wellhead Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating a borehole that produces or is capable of producing oil or natural gas.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Channel Separation Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating the point at which a channel divides separately into two channels.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Marine Farm Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating the existence of a fish, mussel, oyster or pearl farm/culture.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Artificial Reef Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating the existence or the extent of an artificial reef.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Ice Mark">
                <xs:annotation>
                    <xs:documentation>A mark, used year round, that may be submerged when ice passes through the area.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Nature Reserve Mark">
                <xs:annotation>
                    <xs:documentation>A mark used to define the boundary of a nature reserve.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Fish Aggregating Device">
                <xs:annotation>
                    <xs:documentation>A fish aggregating (or aggregation) device (FAD) is a man-made object used to attract ocean going pelagic fish such as marlin, tuna and mahi-mahi (dolphin fish). They usually consist of buoys or floats tethered to the ocean floor with concrete blocks or adrift.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Wreck Mark">
                <xs:annotation>
                    <xs:documentation>A mark used to indicate the existence of a wreck.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Customs Mark">
                <xs:annotation>
                    <xs:documentation>A mark used to indicate the existence of a customs checkpoint.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Causeway Mark">
                <xs:annotation>
                    <xs:documentation>A mark used to indicate the existence of a causeway.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Wave Recorder">
                <xs:annotation>
                    <xs:documentation>A surface following buoy or fixed device used to measure wave activity.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Jetski Prohibited">
                <xs:annotation>
                    <xs:documentation>A mark indicating a jetski prohibited area.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
