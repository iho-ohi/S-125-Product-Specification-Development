    <xs:simpleType name="categoryOfFogSignalLabel">
        <xs:annotation>
            <xs:documentation>Classification of the various means of generating the fog signal.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Explosive">
                <xs:annotation>
                    <xs:documentation>A signal produced by the firing of explosive charges.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Diaphone">
                <xs:annotation>
                    <xs:documentation>A diaphone uses compressed air and generally emits a powerful low-pitched sound, which often concludes with a brief sound of suddenly lowered pitch, termed the 'grunt'.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Siren">
                <xs:annotation>
                    <xs:documentation>A type of fog signal apparatus which produces sound by virtue of the passage of air through slots or holes in a revolving disk.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Nautophone">
                <xs:annotation>
                    <xs:documentation>A horn having a diaphragm oscillated by electricity.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Reed">
                <xs:annotation>
                    <xs:documentation>[1]  A reed uses compressed air and emits a weak, high pitched sound.  [2]  Any of various water or marsh plants with a firm stem. (Concise Oxford English Dictionary)</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Tyfon">
                <xs:annotation>
                    <xs:documentation>A diaphragm horn which operates under the influence of compressed air or steam.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Bell">
                <xs:annotation>
                    <xs:documentation>A ringing sound with a short range.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Whistle">
                <xs:annotation>
                    <xs:documentation>A distinctive sound made by a jet of air passing through an orifice. The apparatus may be operated automatically, by hand or by air being forced up a tube by waves acting on a buoy.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Gong">
                <xs:annotation>
                    <xs:documentation>A sound produced by vibration of a disc when struck.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Horn">
                <xs:annotation>
                    <xs:documentation>A horn uses compressed air or electricity to vibrate a diaphragm and exists in a variety of types which differ greatly in their sound and power.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
