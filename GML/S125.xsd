        </xs:annotation>
        <xs:restriction base="xs:decimal"/>
    </xs:simpleType>
    <xs:complexType name="categoryOfLandmarkType">
        <xs:annotation>
            <xs:documentation>Classification of prominent cultural and natural features in the landscape.</xs:documentation>
        </xs:annotation>
        <xs:simpleContent>
            <xs:extension base="categoryOfLandmarkLabel">
                <xs:attribute name="code" type="categoryOfLandmarkCode" use="required"/>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
    <xs:simpleType name="categoryOfLandmarkLabel">
        <xs:annotation>
            <xs:documentation>Classification of prominent cultural and natural features in the landscape.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Cairn">
                <xs:annotation>
                    <xs:documentation>A mound of stones, usually conical or pyramidal, raised as a landmark or to designate a point of importance in surveying.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Cemetery">
                <xs:annotation>
                    <xs:documentation>A site and associated structures devoted to the burial of the dead.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Chimney">
                <xs:annotation>
                    <xs:documentation>A vertical structure containing a passage or flue for discharging smoke and gases of combustion.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Dish Aerial">
                <xs:annotation>
                    <xs:documentation>A parabolic aerial for the receipt and transmission of high frequency radio signals.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Flagstaff">
                <xs:annotation>
                    <xs:documentation>A staff or pole on which flags are raised.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Flare Stack">
                <xs:annotation>
                    <xs:documentation>A tall structure used for burning-off waste oil or gas.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mast">
                <xs:annotation>
                    <xs:documentation>A relatively tall structure usually held vertical by guy lines.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Windsock">
                <xs:annotation>
                    <xs:documentation>A tapered fabric sleeve mounted so as to catch and swing with the wind, thus indicating the wind direction.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Monument">
                <xs:annotation>
                    <xs:documentation>A structure erected and/or maintained as a memorial to a person and/or event.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Column/Pillar">
                <xs:annotation>
                    <xs:documentation>A cylindrical or slightly tapering body of considerably greater length than diameter erected vertically.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Memorial Plaque">
                <xs:annotation>
                    <xs:documentation>A slab of metal, usually ornamented, erected as a memorial to a person or event.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Obelisk">
                <xs:annotation>
                    <xs:documentation>A tapering shaft usually of stone or concrete, square or rectangular in section, with a pyramidal apex.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Statue">
                <xs:annotation>
                    <xs:documentation>A representation of a living being, sculptured, moulded, or cast in a variety of materials (for example: marble, metal, or plaster).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Cross">
                <xs:annotation>
                    <xs:documentation>A monument, or other structure in form of a cross.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Dome">
                <xs:annotation>
                    <xs:documentation>A landmark comprising a hemispherical or spheroidal shaped structure.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Radar Scanner">
                <xs:annotation>
                    <xs:documentation>A device used for directing a radar beam through a search pattern.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Tower">
                <xs:annotation>
                    <xs:documentation>A relatively tall, narrow structure that may either stand alone or may form part of another structure.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Windmill">
                <xs:annotation>
                    <xs:documentation>A system of vanes attached to a tower and driven by wind (excluding wind turbines).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Windmotor">
                <xs:annotation>
                    <xs:documentation>A modern structure for the use of wind power.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Spire/Minaret">
                <xs:annotation>
                    <xs:documentation>A tall conical or pyramid-shaped structure often built on the roof or tower of a building, especially a church or mosque.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Large Rock or Boulder on Land">
                <xs:annotation>
                    <xs:documentation>An isolated rocky formation or a single large stone.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Triangulation Mark">
                <xs:annotation>
                    <xs:documentation>A recoverable point on the earth, whose geographic position has been determined by angular methods with geodetic instruments. A triangulation point is a selected point, which has been marked with a station mark, or it is a conspicuous natural or artificial feature.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Boundary Mark">
                <xs:annotation>
                    <xs:documentation>A marker identifying the location of a surveyed boundary line.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Observation Wheel">
                <xs:annotation>
                    <xs:documentation>Wheels with passenger cars mounted external to the rim and independently rotated by electric motors.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Torii">
                <xs:annotation>
                    <xs:documentation>A form of decorative gateway or portal, consisting of two upright wooden posts connected at the top by two horizontal crosspieces, commonly found at the entrance to Shinto temples.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Bridge">
                <xs:annotation>
                    <xs:documentation>(1) An elevated structure extending across or over the weather deck of a vessel, or part of such a structure. The term is sometimes modified to indicate the intended use, such as navigating bridge or signal bridge.  (2) A structure erected over a depression or an obstacle such as a body of water, railroad, etc., to provide a roadway for vehicles or pedestrians.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Dam">
                <xs:annotation>
                    <xs:documentation>A barrier to check or confine anything in motion; particularly one constructed to hold back water and raise its level to form a reservoir, or to prevent flooding.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
