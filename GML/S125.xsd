                    <xs:documentation>A mark indicating a Traffic Separation Scheme.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Anchoring Prohibited Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating an anchoring prohibited area.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Berthing Prohibited Mark">
