            <xs:documentation>The specific visibility of a light, with respect to the light's intensity and ease of recognition.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="High Intensity">
                <xs:annotation>
                    <xs:documentation>Non-marine lights with a higher power than marine lights and visible from well off shore (often 'Aero' lights).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Low Intensity">
                <xs:annotation>
                    <xs:documentation>Non-marine lights with lower power than marine lights.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Faint">
                <xs:annotation>
                    <xs:documentation>A decrease in the apparent intensity of a light which may occur in the case of partial obstructions.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Intensified">
                <xs:annotation>
                    <xs:documentation>A light in a sector is intensified (that is, has longer range than other sectors).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Unintensified">
                <xs:annotation>
                    <xs:documentation>A light in a sector is unintensified (that is, has shorter range than other sectors).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Visibility Deliberately Restricted">
                <xs:annotation>
                    <xs:documentation>A light sector is deliberately reduced in intensity, for example to reduce its effect on a built-up area.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Obscured">
                <xs:annotation>
                    <xs:documentation>Said of the arc of a light sector designated by its limiting bearings in which the light is not visible from seaward.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Partially Obscured">
                <xs:annotation>
                    <xs:documentation>This value specifies that parts of the sector are obscured.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Visible in Line of Range">
                <xs:annotation>
                    <xs:documentation>Lights that must be in line to be visible.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
