        <xs:annotation>
            <xs:documentation>The four quadrants (north, east, south and west) are bounded by the true bearings NW-NE, NE-SE, SE-SW and SW-NW taken from the point of interest. A cardinal mark is named after the quadrant in which it is placed. The name of the cardinal mark indicates that it should be passed to the named side of the mark.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="North Cardinal Mark">
                <xs:annotation>
                    <xs:documentation>Quadrant bounded by the true bearing NW-NE taken from the point of interest; it should be passed to the north side of the mark.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="East Cardinal Mark">
                <xs:annotation>
                    <xs:documentation>Quadrant bounded by the true bearing NE-SE taken from the point of interest. It should be passed to the east side of the mark.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="South Cardinal Mark">
                <xs:annotation>
                    <xs:documentation>Quadrant bounded by the true bearing SE-SW taken from the point of interest; it should be passed to the south side of the mark.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="West Cardinal Mark">
                <xs:annotation>
                    <xs:documentation>Quadrant bounded by the true bearing SW-NW taken from the point of interest; it should be passed to the west side of the mark.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="categoryOfCardinalMarkCode">
        <xs:annotation>
            <xs:documentation>The four quadrants (north, east, south and west) are bounded by the true bearings NW-NE, NE-SE, SE-SW and SW-NW taken from the point of interest. A cardinal mark is named after the quadrant in which it is placed. The name of the cardinal mark indicates that it should be passed to the named side of the mark.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:integer">
            <xs:enumeration value="1"> </xs:enumeration>
            <xs:enumeration value="2"> </xs:enumeration>
            <xs:enumeration value="3"> </xs:enumeration>
            <xs:enumeration value="4"> </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="elevationType">
        <xs:annotation>
            <xs:documentation>The altitude of the ground level of a feature, measured from a specified vertical datum.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:decimal"/>
    </xs:simpleType>
    <xs:simpleType name="maximumDisplayScaleType">
        <xs:annotation>
            <xs:documentation>The value considered by the Data Producer to be the maximum (largest) scale at which the data is to be displayed before it can be considered to be “grossly overscaled”.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:int"/>
    </xs:simpleType>
    <xs:simpleType name="minimumDisplayScaleType">
        <xs:annotation>
            <xs:documentation>The smallest intended viewing scale for the data.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:int"/>
    </xs:simpleType>
    <xs:complexType name="categoryOfTemporalVariationType">
        <xs:annotation>
            <xs:documentation>An assessment of the likelihood of change over time.</xs:documentation>
        </xs:annotation>
        <xs:simpleContent>
            <xs:extension base="categoryOfTemporalVariationLabel">
                <xs:attribute name="code" type="categoryOfTemporalVariationCode" use="required"/>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
    <xs:simpleType name="categoryOfTemporalVariationLabel">
        <xs:annotation>
            <xs:documentation>An assessment of the likelihood of change over time.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Extreme Event">
                <xs:annotation>
                    <xs:documentation>Indication of the possible impact of a significant event (for example hurricane, earthquake, volcanic eruption, landslide, etc), which is considered likely to have changed the seafloor or landscape significantly.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Likely to Change and Significant Shoaling Expected">
                <xs:annotation>
                    <xs:documentation>Continuous or frequent change (for example river siltation, sand waves, seasonal storms, icebergs, etc) that is likely to result in new significant shoaling.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Likely to Change But Significant Shoaling Not Expected">
                <xs:annotation>
                    <xs:documentation>Continuous or frequent change (for example sand wave shift, seasonal storms, icebergs, etc) that is not likely to result in new significant shoaling.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Likely to Change">
                <xs:annotation>
                    <xs:documentation>Continuous or frequent change to non-bathymetric features (for example river siltation, glacier creep/recession, sand dunes, buoys, marine farms, etc).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Unlikely to Change">
                <xs:annotation>
                    <xs:documentation>Significant change to the seafloor is not expected.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Unassessed">
                <xs:annotation>
                    <xs:documentation>Not having been assessed.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="categoryOfTemporalVariationCode">
        <xs:annotation>
            <xs:documentation>An assessment of the likelihood of change over time.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:integer">
            <xs:enumeration value="1"> </xs:enumeration>
            <xs:enumeration value="2"> </xs:enumeration>
            <xs:enumeration value="3"> </xs:enumeration>
            <xs:enumeration value="4"> </xs:enumeration>
            <xs:enumeration value="5"> </xs:enumeration>
            <xs:enumeration value="6"> </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="orientationUncertaintyType">
        <xs:annotation>
            <xs:documentation>The best estimate of the accuracy of a bearing.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:decimal"/>
    </xs:simpleType>
    <xs:simpleType name="horizontalDistanceUncertaintyType">
        <xs:annotation>
            <xs:documentation>The best estimate of the horizontal accuracy of horizontal clearances and distances.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:decimal"/>
    </xs:simpleType>
    <xs:complexType name="changeTypesType">
        <xs:annotation>
            <xs:documentation>Different categories or kinds of modifications that can be made to data, positions, or objects. For example, changes may involve updates to position, orientation, or attributes of an object.</xs:documentation>
        </xs:annotation>
        <xs:simpleContent>
            <xs:extension base="changeTypesLabel">
                <xs:attribute name="code" type="changeTypesCode" use="required"/>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
    <xs:simpleType name="changeTypesLabel">
        <xs:annotation>
            <xs:documentation>Different categories or kinds of modifications that can be made to data, positions, or objects. For example, changes may involve updates to position, orientation, or attributes of an object.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Advance Notice of Change">
                <xs:annotation>
                    <xs:documentation>Advance notice of a change to an established Aid to Navigation or establishment of a new Aid to Navigation.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Discrepancy">
                <xs:annotation>
                    <xs:documentation>(1) A difference between results of duplicate or comparable measures of a quantity.  (2) The difference in computed values of a quantity obtained by different processes using data from the same survey.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Proposed Change">
                <xs:annotation>
                    <xs:documentation>Proposed change to an established Aid to Navigation or the establishment of a new Aid to Navigation.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Temporary Change">
                <xs:annotation>
                    <xs:documentation>Temporary change to established or newly established Aid to Navigation to mark a hazard, etc.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Permanent Change">
                <xs:annotation>
                    <xs:documentation>A permanent change to an established Aid to Navigation or establishment of a new Aid to Navigation.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="changeTypesCode">
        <xs:annotation>
            <xs:documentation>Different categories or kinds of modifications that can be made to data, positions, or objects. For example, changes may involve updates to position, orientation, or attributes of an object.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:integer">
            <xs:enumeration value="1"> </xs:enumeration>
            <xs:enumeration value="2"> </xs:enumeration>
            <xs:enumeration value="3"> </xs:enumeration>
            <xs:enumeration value="4"> </xs:enumeration>
            <xs:enumeration value="5"> </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
    <xs:complexType name="featureReferenceType">
        <xs:annotation>
            <xs:documentation>Reference to an object or feature that is external to the dataset.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="atoNNumber" type="atoNNumberType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="interoperabilityIdentifier" type="interoperabilityIdentifierType"
                minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="changeDetailsType">
        <xs:annotation>
            <xs:documentation>Specific information or description regarding modifications or updates made to an object, system, or dataset. This term typically includes the nature, scope, and reason for the change, as well as any impact it may have on operations or functionality</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="atonCommissioning" type="atonCommissioningType" minOccurs="0"
                maxOccurs="1"/>
            <xs:element name="atonRemoval" type="atonRemovalType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="atonReplacement" type="atonReplacementType" minOccurs="0"
                maxOccurs="1"/>
            <xs:element name="fixedAtonChange" type="fixedAtonChangeType" minOccurs="0"
                maxOccurs="1"/>
            <xs:element name="floatingAtonChange" type="floatingAtonChangeType" minOccurs="0"
                maxOccurs="1"/>
            <xs:element name="audibleSignalAtonChange" type="audibleSignalAtonChangeType"
                minOccurs="0" maxOccurs="1"/>
            <xs:element name="lightedAtonChange" type="lightedAtonChangeType" minOccurs="0"
                maxOccurs="1"/>
            <xs:element name="electronicAtonChange" type="electronicAtonChangeType" minOccurs="0"
                maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="obscuredSectorType">
        <xs:annotation>
            <xs:documentation>A portion or sector of a navigational aid, such as a light or beacon, that is blocked or obscured from view due to obstacles (e.g., landforms, buildings, or other structures). In marine or aviation navigation, it usually refers to an area where the light signal or visibility is intentionally or unintentionally reduced or not visible to vessels or aircraft</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="sectorLimit" type="sectorLimitType" minOccurs="1" maxOccurs="1"/>
            <xs:element name="sectorInformation" type="sectorInformationType" minOccurs="0"
                maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="contactAddressType">
        <xs:annotation>
            <xs:documentation>Direction or superscription of a letter, package, etc., specifying the name of the place to which it is directed, and optionally a contact person or organisation who should receive it.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="deliveryPoint" type="deliveryPointType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="cityName" type="cityNameType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="administrativeDivision" type="administrativeDivisionType"
                minOccurs="0" maxOccurs="1"/>
            <xs:element name="countryName" type="countryNameType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="postalCode" type="postalCodeType" minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="featureNameType">
        <xs:annotation>
            <xs:documentation>Provides the name of an entity, defines the national language of the name, and provides the option to display the name at various system display settings.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="language" type="languageType" minOccurs="1" maxOccurs="1"/>
            <xs:element name="name" type="nameType" minOccurs="1" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="fixedDateRangeType">
        <xs:annotation>
            <xs:documentation>An active period of a single fixed event or occurrence, as the date range between discrete start and end dates.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="dateEnd" type="dateEndType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="dateStart" type="dateStartType" minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="expectedOutageType">
        <xs:annotation>
            <xs:documentation>A period in time during which a service, system or device is expected to not be operational.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="dateEnd" type="dateEndType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="dateStart" type="dateStartType" minOccurs="1" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="horizontalPositionUncertaintyType">
        <xs:annotation>
            <xs:documentation>The best estimate of the accuracy of a position.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="uncertaintyFixed" type="uncertaintyFixedType" minOccurs="1"
                maxOccurs="1"/>
            <xs:element name="uncertaintyVariableFactor" type="uncertaintyVariableFactorType"
                minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="informationType">
        <xs:annotation>
            <xs:documentation>Textual information about the feature. The information may be provided as a string of text or as a file name of a single external text file that contains the text.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="fileLocator" type="fileLocatorType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="fileReference" type="fileReferenceType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="headline" type="headlineType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="language" type="languageType" minOccurs="1" maxOccurs="1"/>
            <xs:element name="text" type="textType" minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="multiplicityOfFeaturesType">
        <xs:annotation>
            <xs:documentation>The number of features of identical character that exist as a co-located group.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="multiplicityKnown" type="multiplicityKnownType" minOccurs="1"
                maxOccurs="1"/>
            <xs:element name="numberOfFeatures" type="numberOfFeaturesType" minOccurs="0"
                maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="lightSectorType">
        <xs:annotation>
            <xs:documentation>A sector is the part of a circle between two straight lines drawn from the centre to the circumference.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="colour" type="colourType" minOccurs="1" maxOccurs="unbounded"/>
            <xs:element name="directionalCharacter" type="directionalCharacterType" minOccurs="0"
                maxOccurs="1"/>
            <xs:element name="lightVisibility" type="lightVisibilityType" minOccurs="0"
                maxOccurs="unbounded"/>
            <xs:element name="sectorLimit" type="sectorLimitType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="valueOfNominalRange" type="valueOfNominalRangeType" minOccurs="0"
                maxOccurs="1"/>
            <xs:element name="sectorInformation" type="sectorInformationType" minOccurs="0"
                maxOccurs="unbounded"/>
            <xs:element name="sectorArcExtension" type="sectorArcExtensionType" minOccurs="0"
                maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="directionalCharacterType">
        <xs:annotation>
            <xs:documentation>A directional light is a light illuminating a sector of very narrow angle and intended to mark a direction to follow.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="moireEffect" type="moireEffectType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="orientation" type="orientationType" minOccurs="1" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="orientationType">
        <xs:annotation>
            <xs:documentation>(1) The angular distance measured from true north to the major axis of the feature. (2) In ECDIS, the mode in which information on the ECDIS is being presented. Typical modes include: north-up - as shown on a nautical chart, north is at the top of the display; Ships head-up - based on the actual heading of the ship, (e.g. Ships gyrocompass); course-up display - based on the course or route being taken.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="orientationUncertainty" type="orientationUncertaintyType"
                minOccurs="0" maxOccurs="1"/>
            <xs:element name="orientationValue" type="orientationValueType" minOccurs="1"
                maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="periodicDateRangeType">
        <xs:annotation>
            <xs:documentation>The active period of a recurring event or occurrence.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="dateEnd" type="dateEndType" minOccurs="1" maxOccurs="1"/>
            <xs:element name="dateStart" type="dateStartType" minOccurs="1" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="radarWaveLengthType">
        <xs:annotation>
            <xs:documentation>The distance between two successive peaks (or other points of identical phase) on an electromagnetic wave in the radar band of the electromagnetic spectrum.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="radarBand" type="radarBandType" minOccurs="1" maxOccurs="1"/>
            <xs:element name="waveLengthValue" type="waveLengthValueType" minOccurs="1"
                maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="sectorCharacteristicsType">
        <xs:annotation>
            <xs:documentation>Describes the characteristics of a light sector.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="lightCharacteristic" type="lightCharacteristicType" minOccurs="1"
                maxOccurs="1"/>
            <xs:element name="lightSector" type="lightSectorType" minOccurs="1" maxOccurs="10"/>
            <xs:element name="signalGroup" type="signalGroupType" minOccurs="0" maxOccurs="10"/>
            <xs:element name="signalPeriod" type="signalPeriodType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="signalSequence" type="signalSequenceType" minOccurs="0" maxOccurs="10"
            />
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="sectorInformationType">
        <xs:annotation>
            <xs:documentation>Additional textual information about a light sector.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="language" type="languageType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="text" type="textType" minOccurs="1" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="sectorLimitType">
        <xs:annotation>
            <xs:documentation>A sector is the part of a circle between two straight lines drawn from the centre to the circumference. The sector limit specifies the limits of the sector In a clockwise direction around the central feature (for example a light).</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="sectorLimitOne" type="sectorLimitOneType" minOccurs="1" maxOccurs="1"/>
            <xs:element name="sectorLimitTwo" type="sectorLimitTwoType" minOccurs="1" maxOccurs="1"
            />
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="sectorLimitOneType">
        <xs:annotation>
            <xs:documentation>A sector is the part of a circle between two straight lines drawn from the centre to the circumference. Sector limit one specifies the first limit of the sector. The order of sector limit one and sector limit two is clockwise around the central feature (for example a light).</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="sectorBearing" type="sectorBearingType" minOccurs="1" maxOccurs="1"/>
            <xs:element name="sectorLineLength" type="sectorLineLengthType" minOccurs="0"
                maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="sectorLimitTwoType">
        <xs:annotation>
            <xs:documentation>A sector is the part of a circle between two straight lines drawn from the centre to the circumference. Sector limit two specifies the second limit of the sector. The order of sector limit one and sector limit two is clockwise around the central feature (for example a light).</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="sectorBearing" type="sectorBearingType" minOccurs="1" maxOccurs="1"/>
            <xs:element name="sectorLineLength" type="sectorLineLengthType" minOccurs="0"
                maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="signalSequenceType">
        <xs:annotation>
            <xs:documentation>The sequence of times occupied by intervals of light/sound and eclipse/silence for all “light characteristics” or sound signals.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="signalDuration" type="signalDurationType" minOccurs="1" maxOccurs="1"/>
            <xs:element name="signalStatus" type="signalStatusType" minOccurs="1" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="spatialAccuracyType">
        <xs:annotation>
            <xs:documentation>Provides an indication of the vertical and horizontal positional uncertainty of bathymetric data, optionally within a specified date range.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="fixedDateRange" type="fixedDateRangeType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="horizontalPositionUncertainty"
                type="horizontalPositionUncertaintyType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="verticalUncertainty" type="verticalUncertaintyType" minOccurs="0"
                maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="textualDescriptionType">
        <xs:annotation>
            <xs:documentation>Encodes the file name of a single external text file that contains the text in a defined language, which provides additional textual information that cannot be provided using other allowable attributes for the feature.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="fileReference" type="fileReferenceType" minOccurs="1" maxOccurs="1"/>
            <xs:element name="language" type="languageType" minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="verticalUncertaintyType">
        <xs:annotation>
            <xs:documentation>The best estimate of the vertical accuracy of depths, heights, vertical distances and vertical clearances.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="uncertaintyFixed" type="uncertaintyFixedType" minOccurs="1"
                maxOccurs="1"/>
            <xs:element name="uncertaintyVariableFactor" type="uncertaintyVariableFactorType"
                minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="rhythmOfLightType">
        <xs:annotation>
            <xs:documentation>The sequence of times occupied by intervals of light/sound and eclipse/silence for all light characteristics or sound signals.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <!-- subattributes -->
            <xs:element name="lightCharacteristic" type="lightCharacteristicType" minOccurs="1"
                maxOccurs="1"/>
            <xs:element name="signalGroup" type="signalGroupType" minOccurs="0"
                maxOccurs="unbounded"/>
            <xs:element name="signalPeriod" type="signalPeriodType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="signalSequence" type="signalSequenceType" minOccurs="0"
                maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="SpatialQualityType" abstract="false">
        <xs:annotation>
            <xs:documentation>The indication of the quality of the locational information for features in a dataset.</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="S100:AbstractInformationType">
                <xs:sequence>
                    <!-- attributes -->
                    <!--0-->
                    <xs:element name="qualityOfVerticalMeasurement"
                        type="qualityOfVerticalMeasurementType" minOccurs="0" maxOccurs="1"/>
                    <!--1-->
                    <xs:element name="spatialAccuracy" type="spatialAccuracyType" minOccurs="0"
                        maxOccurs="1"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="AtonStatusInformationType" abstract="false">
