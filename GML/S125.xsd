                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Pipe">
                <xs:annotation>
                    <xs:documentation>A vertical hollow cylinder of metal, wood, or other material forced into the earth or seabed.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mooring Post">
