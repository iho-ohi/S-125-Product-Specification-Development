    <xs:simpleType name="lightCharacteristicLabel">
        <xs:annotation>
            <xs:documentation>The distinct character, such as fixed, flashing, or occulting, which is given to each light to avoid confusion with neighbouring ones.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Fixed">
                <xs:annotation>
                    <xs:documentation>A signal light that shows continuously, in any given direction, with constant luminous intensity and colour.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Flashing">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which the total duration of light in a period is clearly shorter than the total duration of darkness and all the appearances of light are of equal duration.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Long-Flashing">
                <xs:annotation>
                    <xs:documentation>A single-flashing light in which an appearance of light of not less than two seconds duration is regularly repeated.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Quick-Flashing">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which flashes are repeated at a rate of not less than 50 flashes per minutes but less than 80 flashes per minutes. It may be: - Continuous quick-flashing: A quick-flashing light in which a flash is regularly repeated. - Group quick-flashing: A quick-flashing light in which a group of two or more flashes, which are specified in number, is regularly repeated.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Very Quick-Flashing">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which flashes are repeated at a rate of not less than 80 flashes per minute but less than 160 flashes per minute. It may be:- Continuous very quick-flashing: A very quick-flashing light in which a flash is regularly repeated.- Group very quick-flashing: A very quick-flashing light in which a group of two or more flashes, which are specified in number, is regularly repeated.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Continuous Ultra Quick-Flashing">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which flashes are regularly repeated at a rate of not less than 160 flashes per minute.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Isophased">
                <xs:annotation>
                    <xs:documentation>A light with all durations of light and darkness equal.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Occulting">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which the total duration of light in a period is clearly longer than the total duration of darkness and all the eclipses are of equal duration. It may be:  - Single-occulting: An occulting light in which an eclipse is regularly repeated.  - Group-occulting: An occulting light in which a group of two or more eclipses, which are specified in number, is regularly repeated.  - Composite group-occulting: An occulting light in which a sequence of groups of one or more eclipses, which are specified in number, is regularly repeated, and the groups comprise different numbers of eclipses.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Interrupted Quick Flashing">
                <xs:annotation>
                    <xs:documentation>A quick light in which the sequence of flashes is interrupted by regularly repeated eclipses of constant and long duration.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Interrupted Very Quick Flashing">
                <xs:annotation>
                    <xs:documentation>A light in which the very rapid alterations of light and darkness are interrupted at regular intervals by eclipses of long duration.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Interrupted Ultra Quick-Flashing">
                <xs:annotation>
                    <xs:documentation>A light in which the ultra quick flashes (160 or more per minute) are interrupted at regular intervals by eclipses of long duration.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Morse">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which appearances of light of two clearly different durations are grouped to represent a character or characters in the Morse code.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Fixed and Flash">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which a fixed light is combined with a flashing light of higher luminous intensity.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Flash and Long-Flash">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which a flashing light is combined with a long-flashing light of higher luminous intensity.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Occulting and Flash">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which an occulting light is combined with a flashing light of higher luminous intensity.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Fixed and Long-Flash">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which a fixed light is combined with a long-flashing light of higher luminous intensity.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Occulting Alternating">
                <xs:annotation>
                    <xs:documentation>An alternating light in which the total duration of light in each period is clearly longer than the total duration of darkness and in which the intervals of darkness (occultations) are all of equal duration.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Long-Flash Alternating">
                <xs:annotation>
                    <xs:documentation>An alternating single-flashing light in which an appearance of light of not less than two seconds duration is regularly repeated.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Flash Alternating">
                <xs:annotation>
                    <xs:documentation>An alternating rhythmic light in which the total duration of light in a period is clearly shorter than the total duration of darkness and all the appearances of light are of equal duration.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Group Alternating">
                <xs:annotation>
                    <xs:documentation>Occulting light in which the occultations are combined in groups, each group including the same number of occultations, and in which the groups are repeated at regular intervals.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Quick-Flash Plus Long-Flash">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which a group of quick flashes is followed by one or more long flashes in a regularly repeated sequence with a regular periodicity.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Very Quick-Flash Plus Long-Flash">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which a group of very quick flashes is followed by one or more long flashes in a regularly repeated sequence with a regular periodicity.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Ultra Quick-Flash Plus Long-Flash">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which a group of ultra quick flashes is followed by one or more long flashes in a regularly repeated sequence with a regular periodicity.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Alternating">
                <xs:annotation>
                    <xs:documentation>A signal light that shows continuously, in any given direction, two or more colours in a regularly repeated sequence with a regular periodicity.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Fixed and Alternating Flashing">
                <xs:annotation>
                    <xs:documentation>A rhythmic light in which a fixed light is combined with a flashing light of higher luminous intensity and different colour.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Group-Occulting Light">
                <xs:annotation>
                    <xs:documentation>An occulting light in which a group of two or more eclipses, which are specified in number, is regularly repeated</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Composite Group-Occulting Light">
                <xs:annotation>
                    <xs:documentation>An occulting light in which a sequence of groups of one or more eclipses, which are specified in number, is regularly repeated, and the groups comprise different numbers of eclipses.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Group Flashing Light">
                <xs:annotation>
                    <xs:documentation>A flashing light in which a group of flashes, specified in number, is regularly repeated.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Composite Group-Flashing Light">
                <xs:annotation>
                    <xs:documentation>A light similar to a group-flashing light except that successive groups in a period have different numbers of flashes.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
