    <xs:simpleType name="uncertaintyFixedType">
        <xs:annotation>
            <xs:documentation>The best estimate of the fixed horizontal or vertical accuracy component for positions, depths, heights, vertical distances and vertical clearances.</xs:documentation>
        </xs:annotation>
