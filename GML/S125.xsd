                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Restricted Vertical Clearance Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating the minimum vertical space available for passage.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Maximum Vessel's Draught Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating the maximum draught of vessel permitted.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Restricted Horizontal Clearance Mark">
