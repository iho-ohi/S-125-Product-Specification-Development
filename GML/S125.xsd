        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="heightType">
        <xs:annotation>
            <xs:documentation>The value of the vertical distance to the highest point of the feature, measured from a specified vertical datum.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:decimal"/>
    </xs:simpleType>
    <xs:simpleType name="verticalLengthType">
        <xs:annotation>
