                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Recording Mark">
                <xs:annotation>
                    <xs:documentation>A mark used to record data for scientific purposes.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Seaplane Anchorage Mark">
                <xs:annotation>
                    <xs:documentation>A mark used to indicate a seaplane anchorage.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Recreation Zone Mark">
                <xs:annotation>
                    <xs:documentation>A mark used to indicate a recreation zone.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Private Mark">
                <xs:annotation>
                    <xs:documentation>A privately maintained mark.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mooring Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating a mooring or moorings.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="LANBY">
                <xs:annotation>
                    <xs:documentation>A large buoy designed to take the place of a lightship where construction of an offshore light station is not feasible.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Leading Mark">
                <xs:annotation>
