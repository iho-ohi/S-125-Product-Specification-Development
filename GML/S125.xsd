    <xs:complexType name="topmarkDaymarkShapeType">
        <xs:annotation>
            <xs:documentation>The shape a topmark or daymark exhibits.</xs:documentation>
        </xs:annotation>
        <xs:simpleContent>
            <xs:extension base="topmarkDaymarkShapeLabel">
