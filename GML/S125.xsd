    <xs:simpleType name="functionLabel">
        <xs:annotation>
            <xs:documentation>A specific role that describes a feature.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Harbour-Masters Office">
                <xs:annotation>
                    <xs:documentation>A local official who has charge of mooring and berthing of vessels, collecting harbour fees, etc.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Customs Office">
                <xs:annotation>
                    <xs:documentation>Serves as a government office where customs duties are collected, the flow of goods are regulated and restrictions enforced, and shipments or vehicles are cleared for entering or leaving a country.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Health Office">
                <xs:annotation>
                    <xs:documentation>The office which is charged with the administration of health laws and sanitary inspections.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Hospital">
                <xs:annotation>
                    <xs:documentation>An institution or establishment providing medical or surgical treatment for the ill or wounded.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Post Office">
                <xs:annotation>
                    <xs:documentation>The public department, agency or organisation responsible primarily for the collection, transmission and distribution of mail.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Hotel">
                <xs:annotation>
                    <xs:documentation>An establishment, especially of a comfortable or luxurious kind, where paying visitors are provided with accommodation, meals and other services.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Railway Station">
                <xs:annotation>
                    <xs:documentation>A building with platforms where trains arrive, load, discharge and depart.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Police Station">
                <xs:annotation>
                    <xs:documentation>The headquarters of a local police force and that is where those under arrest are first charged.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Water-Police Station">
                <xs:annotation>
                    <xs:documentation>The headquarters of a local water-police force.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Pilot Office">
                <xs:annotation>
                    <xs:documentation>The office or headquarters of pilots; the place where the services of a pilot may be obtained.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Pilot Lookout">
                <xs:annotation>
                    <xs:documentation>A distinctive structure or place on shore from which personnel keep watch upon events at sea or along the coast.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Bank Office">
                <xs:annotation>
                    <xs:documentation>An office for custody, deposit, loan, exchange or issue of money.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Headquarters for District Control">
                <xs:annotation>
                    <xs:documentation>The quarters of an executive officer (director, manager, etc.) with responsibility for an administrative area.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Transit Shed/Warehouse">
                <xs:annotation>
                    <xs:documentation>A building or part of a building for storage of wares or goods.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Factory">
                <xs:annotation>
                    <xs:documentation>A building or buildings with equipment for manufacturing; a workshop.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Power Station">
                <xs:annotation>
                    <xs:documentation>A stationary plant containing apparatus for large scale conversion of some form of energy (such as hydraulic, steam, chemical or nuclear energy) into electrical energy.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Administrative">
                <xs:annotation>
                    <xs:documentation>A building for the management of affairs.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Educational Facility">
                <xs:annotation>
                    <xs:documentation>An establishment for teaching and learning (for example school, college, university, etc).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Church">
                <xs:annotation>
                    <xs:documentation>A building for public Christian worship.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Chapel">
                <xs:annotation>
                    <xs:documentation>A place for Christian worship other than a parish, cathedral or church, especially one attached to a private house or institution.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Temple">
                <xs:annotation>
                    <xs:documentation>A building for public Jewish worship.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Pagoda">
                <xs:annotation>
                    <xs:documentation>A Hindu or Buddhist temple or sacred building.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Shinto Shrine">
                <xs:annotation>
                    <xs:documentation>A building for public Shinto worship.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Buddhist Temple">
                <xs:annotation>
                    <xs:documentation>A building for public Buddhist worship.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mosque">
                <xs:annotation>
                    <xs:documentation>A Muslim place of worship.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Marabout">
                <xs:annotation>
                    <xs:documentation>A shrine marking the burial place of a Muslim holy man.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Lookout">
                <xs:annotation>
                    <xs:documentation>Keeping a watch upon events at sea or along the coast.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Communication">
                <xs:annotation>
                    <xs:documentation>Transmitting and/or receiving electronic communication signals.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Television">
                <xs:annotation>
                    <xs:documentation>A system for reproducing on a screen visual images transmitted (usually with sound) by radio signals.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Radio">
                <xs:annotation>
                    <xs:documentation>Transmitting and/or receiving radio-frequency electromagnetic waves as a means of communication.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Radar">
                <xs:annotation>
                    <xs:documentation>A method, system or technique of using beamed, reflected, and timed radio waves for detecting, locating, or tracking objects, and for measuring altitudes.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Light Support">
                <xs:annotation>
                    <xs:documentation>A structure serving as a support for one or more lights.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Microwave">
                <xs:annotation>
                    <xs:documentation>Broadcasting and receiving signals using microwaves.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Cooling">
                <xs:annotation>
                    <xs:documentation>Generation of chilled liquid and/or gas for cooling purposes.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Observation">
                <xs:annotation>
                    <xs:documentation>A place from which the surroundings can be observed but at which a watch is not habitually maintained.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Timeball">
                <xs:annotation>
                    <xs:documentation>A visual time signal in the form of a ball.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Clock">
                <xs:annotation>
                    <xs:documentation>Instrument for measuring time and recording hours.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Control">
                <xs:annotation>
                    <xs:documentation>Used to control the flow of traffic within a specified range of an installation.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Airship Mooring">
                <xs:annotation>
                    <xs:documentation>Equipment or structure to secure an airship.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Stadium">
                <xs:annotation>
                    <xs:documentation>An arena for holding and viewing events.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Bus Station">
                <xs:annotation>
                    <xs:documentation>A building where buses and coaches regularly stop to take on and/or let off passengers, especially for long-distance travel.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Passenger Terminal Building">
                <xs:annotation>
                    <xs:documentation>A building within a terminal for the loading and unloading of passengers.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Sea Rescue Control">
                <xs:annotation>
                    <xs:documentation>A unit responsible for promoting efficient organization of search and rescue services and for coordinating the conduct of search and rescue operations within a search and rescue region.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Observatory">
                <xs:annotation>
                    <xs:documentation>A building designed and equipped for making observations of astronomical, meteorological, or other natural phenomena.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Ore Crusher">
                <xs:annotation>
                    <xs:documentation>A building or structure used to crush ore.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Boathouse">
                <xs:annotation>
                    <xs:documentation>A building or shed, usually built partly over water, for sheltering a boat or boats.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Pumping Station">
                <xs:annotation>
                    <xs:documentation>A facility to move solids, liquids or gases by means of pressure or suction.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Roof Above Navigable Water">
                <xs:annotation>
                    <xs:documentation>A roof that is extending above navigable water, e.g. to protect open cargo holds from rain during loading and unloading. Depending on the vertical clearance vessels can pass under the roof above navigable water.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Building Above Navigable Water">
                <xs:annotation>
                    <xs:documentation>The part of a building on land that is extending above navigable water. Depending on the vertical clearance vessels can pass under the building above navigable water.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
