    <xs:simpleType name="verticalDatumLabel">
        <xs:annotation>
            <xs:documentation>The reference level used for expressing the vertical measurements of points on the earth's surface. Also called datum level, reference plane, levelling datum, datum for sounding reduction, datum for heights.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Mean Low Water Springs">
                <xs:annotation>
                    <xs:documentation>The average height of the low waters of spring tides. This level is used as a tidal datum in some areas.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mean Lower Low Water Springs">
                <xs:annotation>
                    <xs:documentation>The average height of lower low water springs at a place.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mean Sea Level">
                <xs:annotation>
                    <xs:documentation>The average height of the surface of the sea at a tide station for all stages of the tide over a 19-year period, usually determined from hourly height readings measured from a fixed predetermined reference level.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Lowest Low Water">
                <xs:annotation>
                    <xs:documentation>An arbitrary level conforming to the lowest tide observed at a place, or somewhat lower.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mean Low Water">
                <xs:annotation>
                    <xs:documentation>The average height of all low waters at a place over a 19-year period.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Lowest Low Water Springs">
                <xs:annotation>
                    <xs:documentation>An arbitrary level conforming to the lowest water level observed at a place at spring tides during a period of time shorter than 19 years.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Approximate Mean Low Water Springs">
                <xs:annotation>
                    <xs:documentation>An arbitrary level, usually within 0.3m from that of Mean Low Water Springs (MLWS).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Indian Spring Low Water">
                <xs:annotation>
                    <xs:documentation>An arbitrary tidal datum approximating the level of the mean of the lower low water at spring tides. It was first used in waters surrounding India.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Low Water Springs">
                <xs:annotation>
                    <xs:documentation>An arbitrary level, approximating that of mean low water springs (MLWS).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Approximate Lowest Astronomical Tide">
                <xs:annotation>
                    <xs:documentation>An arbitrary level, usually within 0.3m from that of Lowest Astronomical Tide (LAT).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Nearly Lowest Low Water">
                <xs:annotation>
                    <xs:documentation>An arbitrary level approximating the lowest water level observed at a place, usually equivalent to the Indian Spring Low Water (ISLW).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mean Lower Low Water">
                <xs:annotation>
                    <xs:documentation>The average height of the lower low waters at a place over a 19-year period.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Low Water">
                <xs:annotation>
                    <xs:documentation>The lowest level reached at a place by the water surface in one oscillation.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Approximate Mean Low Water">
                <xs:annotation>
                    <xs:documentation>An arbitrary level, usually within 0.3m from that of Mean Low Water (MLW).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Approximate Mean Lower Low Water">
                <xs:annotation>
                    <xs:documentation>An arbitrary level, usually within 0.3m from that of Mean Lower Low Water (MLLW).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mean High Water">
                <xs:annotation>
                    <xs:documentation>The average height of all high waters at a place over a 19-year period.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mean High Water Springs">
                <xs:annotation>
                    <xs:documentation>The average height of the high waters of spring tides.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="High Water">
                <xs:annotation>
                    <xs:documentation>The highest level reached at a place by the water surface in one oscillation.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Approximate Mean Sea Level">
                <xs:annotation>
                    <xs:documentation>An arbitrary level, usually within 0.3m from that of Mean Sea Level (MSL).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="High Water Springs">
                <xs:annotation>
                    <xs:documentation>An arbitrary level, approximating that of mean high water springs (MHWS).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mean Higher High Water">
                <xs:annotation>
                    <xs:documentation>The average height of higher high waters at a place over a 19-year period.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Equinoctial Spring Low Water">
                <xs:annotation>
                    <xs:documentation>The level of low water springs near the time of an equinox.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Lowest Astronomical Tide">
                <xs:annotation>
                    <xs:documentation>The lowest tide level which can be predicted to occur under average meteorological conditions and under any combination of astronomical conditions.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Local Datum">
                <xs:annotation>
                    <xs:documentation>An arbitrary datum defined by a local harbour authority, from which levels and tidal heights are measured by this authority.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="International Great Lakes Datum 1985">
                <xs:annotation>
                    <xs:documentation>A vertical reference system with its zero based on the mean water level at Rimouski/Pointe-au-Père, Quebec, over the period 1970 to 1988.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mean Water Level">
                <xs:annotation>
                    <xs:documentation>The average of all hourly water levels over the available period of record.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Lower Low Water Large Tide">
                <xs:annotation>
                    <xs:documentation>The average of the lowest low waters, one from each of 19 years of observations.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Higher High Water Large Tide">
                <xs:annotation>
                    <xs:documentation>The average of the highest high waters, one from each of 19 years of observations.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Nearly Highest High Water">
                <xs:annotation>
                    <xs:documentation>An arbitrary level approximating the highest water level observed at a place, usually equivalent to the high water springs.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Highest Astronomical Tide">
                <xs:annotation>
                    <xs:documentation>The highest tidal level which can be predicted to occur under average meteorological conditions and under any combination of astronomical conditions.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Local Low Water Reference Level">
                <xs:annotation>
                    <xs:documentation>Low water reference level of the local area.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Local High Water Reference Level">
                <xs:annotation>
                    <xs:documentation>High water reference level of the local area.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Local Mean Water Reference Level">
                <xs:annotation>
                    <xs:documentation>Mean water reference level of the local area.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Equivalent Height of Water (German GlW)">
                <xs:annotation>
                    <xs:documentation>A low water level which is the result of a defined low water discharge - called "equivalent discharge".</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Highest Shipping Height of Water (German HSW)">
                <xs:annotation>
                    <xs:documentation>Upper limit of water levels where navigation is allowed.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Reference Low Water Level According to Danube Commission">
                <xs:annotation>
                    <xs:documentation>The water level at a discharge, which is exceeded 94 % of the year within a period of 30 years.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Highest Shipping Height of Water According to Danube Commission">
                <xs:annotation>
                    <xs:documentation>The water level at a discharge, which is exceeded 1% of the year within a period of 30 years.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Dutch River Low Water Reference Level (OLR)">
                <xs:annotation>
                    <xs:documentation>The water level at a discharge, which is exceeded 95% of the year within a period of 20 years.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Russian Project Water Level">
                <xs:annotation>
                    <xs:documentation>Conditional low water level with established probability.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Russian Normal Backwater Level">
                <xs:annotation>
                    <xs:documentation>Highest water level derived from the upper backwater stream in watercourse or reservoir under the normal operational conditions.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Ohio River Datum">
                <xs:annotation>
                    <xs:documentation>The Ohio River datum.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Dutch High Water Reference Level">
                <xs:annotation>
                    <xs:documentation>Dutch High Water Reference Level.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Baltic Sea Chart Datum 2000">
                <xs:annotation>
                    <xs:documentation>The datum refers to each Baltic country's realization of the European Vertical Reference System (EVRS) with land-uplift epoch 2000, which is connected to the Normaal Amsterdams Peil (NAP).</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Dutch Estuary Low Water Reference Level (OLW)">
                <xs:annotation>
                    <xs:documentation>Dutch Estuary Low Water Reference Level (OLW)</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="International Great Lakes Datum 2020">
                <xs:annotation>
                    <xs:documentation>The 2020 update to the International Great Lakes Datum, the official reference system used to measure water level heights in the Great Lakes, connecting channels, and the St. Lawrence River system.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Sea Floor">
                <xs:annotation>
                    <xs:documentation>The bottom of the ocean and seas where there is a generally smooth gentle gradient. Also referred to as sea bed (sometimes seabed or sea-bed), and sea bottom.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Sea Surface">
                <xs:annotation>
                    <xs:documentation>A two-dimensional (in the horizontal plane) field representing the air-sea interface, with high-frequency fluctuations such as wind waves and swell, but not astronomical tides, filtered out.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Hydrographic Zero">
                <xs:annotation>
                    <xs:documentation>A vertical reference near the lowest astronomical tide (LAT), below which the sea level falls only very exceptionally.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
