        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Under Construction">
                <xs:annotation>
                    <xs:documentation>Being built but not yet capable of function.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Ruined">
                <xs:annotation>
                    <xs:documentation>A structure in a decayed or deteriorated condition resulting from neglect or disuse, or a damaged structure in need of repair.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Under Reclamation">
                <xs:annotation>
                    <xs:documentation>An area of the sea, a lake or the navigable part of a river that is being reclaimed as land, usually by the dumping of earth and other material.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Wingless">
                <xs:annotation>
                    <xs:documentation>A windmill or wind turbine from which the vanes or turbine blades are missing.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Planned Construction">
                <xs:annotation>
                    <xs:documentation>Detailed planning has been completed but construction has not been initiated.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
