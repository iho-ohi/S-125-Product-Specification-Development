                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Telephone Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating the presence of a telephone.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Ferry Crossing Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating that a ferry route crosses the ship route; often used with a 'sound ship's siren' mark.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Pipeline Mark">
                <xs:annotation>
                    <xs:documentation>A mark used to indicate the position of submarine pipelines or the point at which they run on to the land.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Anchorage Mark">
                <xs:annotation>
                    <xs:documentation>A mark indicating an anchorage area.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Clearing Mark">
                <xs:annotation>
