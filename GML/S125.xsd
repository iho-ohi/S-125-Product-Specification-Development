                    <xs:documentation>An object that may be visible from seaward, but cannot be used as a fixing mark and is not conspicuous.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Prominent">
                <xs:annotation>
                    <xs:documentation>Objects which are easily identifiable, but do not justify being classed as conspicuous.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="visualProminenceCode">
        <xs:annotation>
            <xs:documentation>The extent to which a feature, either natural or artificial, is visible from seaward.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:integer">
            <xs:enumeration value="1"> </xs:enumeration>
            <xs:enumeration value="2"> </xs:enumeration>
