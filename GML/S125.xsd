                    <xs:documentation>Indicates a bridge pier in an inland waterway.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Entry From a Lake to a Narrower Waterway, Right Bank">
                <xs:annotation>
                    <xs:documentation>Indicates the right bank of the entry from a lake or a lake-like expansion to a section of the waterway which is narrower.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Entry From a Lake to a Narrower Waterway, Left Bank">
