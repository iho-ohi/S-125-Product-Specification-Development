                    <xs:documentation>Term used with leading lights to describe the position of the light on the lead as viewed from seaward.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Emergency">
                <xs:annotation>
                    <xs:documentation>A light available as a backup to a main light which will be illuminated should the main light fail.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Bearing Light">
