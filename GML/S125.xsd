    <xs:simpleType name="categoryOfOffshorePlatformLabel">
        <xs:annotation>
            <xs:documentation>Classification of an offshore raised structure.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Oil Rig">
                <xs:annotation>
                    <xs:documentation>A temporary mobile structure, either fixed or floating, used in the exploration stages of oil and gas fields.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Production Platform">
                <xs:annotation>
                    <xs:documentation>A term used to indicate a permanent offshore structure equipped to control the flow of oil or gas. It does not include entirely submarine structures.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Observation/Research Platform">
                <xs:annotation>
                    <xs:documentation>A platform from which one's surroundings or events can be observed, noted or recorded such as for scientific study.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Articulated Loading Platform">
                <xs:annotation>
                    <xs:documentation>A metal lattice tower, buoyant at one end and attached at the other by a universal joint to a concrete filled base on the seabed. The platform may be fitted with a helicopter platform, emergency accommodation and hawser/hose retrieval.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Single Anchor Leg Mooring">
                <xs:annotation>
                    <xs:documentation>A rigid frame or tube with a buoyancy device at its upper end, secured at its lower end to a universal joint on a large steel or concrete base resting on the seabed, and at its upper end to a mooring buoy by a chain or wire.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Mooring Tower">
                <xs:annotation>
                    <xs:documentation>A platform secured to the seabed and surmounted by a turntable to which ships moor.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Artificial Island">
                <xs:annotation>
                    <xs:documentation>A man-made structure usually built for the exploration or exploitation of marine resources, marine scientific research, tidal observations, etc.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Floating Production, Storage and Off-Loading Vessel">
                <xs:annotation>
                    <xs:documentation>An offshore facility consisting of a moored tanker/barge by which the product is extracted, stored and exported.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Accommodation Platform">
                <xs:annotation>
                    <xs:documentation>A platform used primarily for eating, sleeping and recreation purposes.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Navigation, Communication and Control Buoy">
                <xs:annotation>
                    <xs:documentation>A floating structure with control room, power and storage facilities, attached to the seabed by a flexible pipeline and cables.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Floating Oil Tank">
                <xs:annotation>
                    <xs:documentation>A floating structure, anchored to the seabed, for storing oil.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
